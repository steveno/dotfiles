[user]
        name = Steven Oliver
        email = oliver.steven@gmail.com
[core]
        excludesfile = ~/.gitignore
[color]
        branch = auto
        diff = auto
        status = auto
        ui = auto
[alias]
        br = branch
        cl = clone
        co = checkout
        ll = log --graph --decorate
        ss = status -sb
[sendemail]
        confirm = always
        chainreplyto = false
        smtpencryption = tls
        smtpserver = smtp.gmail.com
        smtpuser = oliver.steven@gmail.com
        smtpserverport = 587
[github]
        name = steveno
[push]
	default = simple
